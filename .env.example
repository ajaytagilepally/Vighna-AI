# ============================================
# Vighna AI - Environment Configuration
# Powered by Ollama (Free, Local AI Models)
# ============================================

# Ollama Configuration (LOCAL - No API keys needed!)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_CODE_MODEL=codellama
OLLAMA_TIMEOUT=120  # seconds
OLLAMA_NUM_THREADS=4

# Database Configuration
# Using SQLite for simplicity (no external DB needed)
DATABASE_URL=sqlite:///./vighna_ai.db
# For PostgreSQL, uncomment and update:
# DATABASE_URL=postgresql://user:password@localhost:5432/vighna_ai

# Redis Configuration (Optional - for caching)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend Services Ports
PYTHON_BACKEND_URL=http://localhost:8000
PYTHON_BACKEND_PORT=8000
NODEJS_BACKEND_URL=http://localhost:3000
NODEJS_BACKEND_PORT=3000

# Frontend
ANGULAR_FRONTEND_URL=http://localhost:4200
ANGULAR_FRONTEND_PORT=4200

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# Application Settings
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=info  # debug, info, warning, error

# CORS Configuration
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Logging
LOG_FORMAT=json
LOG_DIR=./logs

# Security
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_COOKIES=false
SAMESITE_COOKIES=Lax

# Chat Settings
CONVERSATION_HISTORY_LIMIT=50
MAX_CONTEXT_LENGTH=4096
DEFAULT_TEMPERATURE=0.7
DEFAULT_TOP_P=0.9

# Code Generation Settings
CODE_GENERATION_TEMPERATURE=0.2  # Lower for more deterministic code
CODE_ANALYSIS_ENABLED=true
CODE_EXPLANATION_ENABLED=true
